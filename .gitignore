# SSH snapshot pulls (secrets + timestamps): keep local only, never commit
app/config/server_snapshots/
gha_deploy_key
gha_deploy_key.pub
*deploy_key*
*.pem
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# --- Packaging / build ---
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# --- Tool caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# --- IDE / OS ---
.idea/
.vscode/
.DS_Store

# --- Runtime data / logs ---
data/
*.log
*.jsonl

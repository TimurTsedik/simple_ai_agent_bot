# --- Python bytecode / cache ---
__pycache__/
*.py[cod]
*$py.class

# --- Virtual environments ---
.venv/
venv/
env/

# --- Environment / secrets ---
.env
.env.*
!.env.example
data/memory/sessions/*/tools.yaml
data/memory/sessions/*/schedules.yaml
